{
  "name": "ohsboard",
  "version": "0.0.0",
  "private": true,
  "packageManager": "pnpm@9.12.0",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "web:dev": "dotenv -e .env.local -- pnpm --filter @ohsboard/web dev",
    "web:build": "dotenv -e .env.local -- pnpm --filter @ohsboard/web build",
    "worker:dev": "dotenv -e .env.local -- pnpm --filter @ohsboard/worker dev",
    "worker:start": "dotenv -e .env.local -- pnpm --filter @ohsboard/worker start",
    "worker:nba:test": "dotenv -e .env.local -- pnpm --filter @ohsboard/worker nba:test",
    "worker:nba:verify": "dotenv -e .env.local -- pnpm --filter @ohsboard/worker nba:verify",
    "worker:nba:heal-sim": "dotenv -e .env.local -- pnpm --filter @ohsboard/worker nba:heal-sim",
    "db:generate": "dotenv -e .env.local -- pnpm --filter @ohsboard/db generate",
    "db:push": "dotenv -e .env.local -- pnpm --filter @ohsboard/db push",
    "db:seed": "dotenv -e .env.local -- pnpm --filter @ohsboard/db seed",
    "db:studio": "dotenv -e .env.local -- pnpm --filter @ohsboard/db studio",
    "fetch:logos": "tsx scripts/fetch-mlb-logos.ts",
    "fetch:nba-logos": "tsx scripts/fetch-nba-logos.ts",
    "typecheck": "pnpm -r typecheck"
  },
  "devDependencies": {
    "dotenv-cli": "^8.0.0",
    "typescript": "^5.6.3"
  }
}
