# Copy this file to .env.local and fill in real values.
# .env.local is gitignored; .env.example is the committed template — never put real secrets here.

# Neon Postgres connection string (pooled is fine for the web app; direct is fine for migrations)
DATABASE_URL=postgresql://<user>:<password>@<host>.neon.tech/<db>?sslmode=require&channel_binding=require

# Shared secret the web app uses to call the worker's /trigger endpoint.
# Any long random string works — generate with: openssl rand -hex 32
WORKER_SECRET=replace-with-long-random-string

# URL where the worker's HTTP server is reachable. Local dev default:
WORKER_URL=http://localhost:8080

# OpenAI credentials — only the worker needs these (for selector self-healing in M6+)
# Can stay blank until M6; healer is stubbed.
OPENAI_API_KEY=sk-...
OPENAI_ORG_ID=org-...
# Optional; defaults to gpt-5 if unset
OPENAI_MODEL=gpt-5

# Optional: Resend API key for circuit-breaker email alerts (M8)
RESEND_API_KEY=

# Optional: unguessable path segment for the /status diagnostic page (M8)
STATUS_PAGE_SECRET=change-me

# Optional: set HEADLESS=false to watch the scraper in a visible Chromium window
# (useful for debugging selector/nav issues locally). Defaults to true.
HEADLESS=true
